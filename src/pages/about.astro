---
import boeingLogo from "@assets/branding/boeing.png";
import geneHaasLogo from "@assets/branding/genehaas.jpg";
import intuitiveLogo from "@assets/branding/intuitivefoundation.png";
import rockwellLogo from "@assets/branding/rockwell.svg";
import unswLogo from "@assets/branding/unsweet.png";
import awardsImage from "@assets/photos/awards.jpg";
import teamImage from "@assets/photos/team-2025.jpg";
import InlineLink from "@components/InlineLink.astro";
import ResponsiveImage from "@components/ResponsiveImage.astro";
import Layout from "@layouts/Layout.astro";

const accomplishments = [
  {
    year: 2012,
    items: ["EMU Robotics is born!"],
  },
  {
    year: 2013,
    items: ["We participated in our first FRC Event, DDU (Duel Down Under)."],
  },
  {
    year: 2014,
    items: [
      "We opened a stall in our first yearly UNSW Open Day, exposing students of all ages to robotics and FRC.",
    ],
  },
  {
    year: 2015,
    items: ["We participated in our first FRC Regional Event."],
  },
  {
    year: 2016,
    items: [
      "We won our first FRC Awards in 2016 - a design award for our grappling hook and the Motivate award.",
      "We hosted our GERRIC courses, teaching year 5 and 6 students about robotics.",
    ],
  },
  {
    year: 2018,
    items: [
      "We won the Gracious Professionalism award at DDU as we helped other teams.",
    ],
  },
  {
    year: 2019,
    items: [
      "We formed the Junior Team, with 20 late primary/early high school students joining in the first meeting.",
      "We participated in our first FLL competition, in which our 2 teams came second and fourth.",
    ],
  },
  {
    year: 2020,
    items: [
      "We held robotics workshops for high school students.",
      "We went online due to social distancing restrictions, and managed to participate in the FLL competition that year, progressing to Nationals.",
    ],
  },
  {
    year: 2021,
    items: [
      "We were wildcarded into FLL APOC (Asia Pacific Open Championships), winning the Motivate award.",
    ],
  },
  {
    year: 2022,
    items: [
      "We return to the FRC competition with our robot being built on the front porch of a team member.",
      "We, along with our alliance partners, won the DDU playoffs.",
    ],
  },
  {
    year: 2023,
    items: [
      "We participated in our first yearly Rhodes Robot Ball, exposing the local youth to our robot.",
      "We held our first yearly Open Night, and saw about 60 students and parents visit us, many of which who joined the team.",
      "We started the EMU Chicks team for 7-10 year olds.",
    ],
  },
  {
    year: 2024,
    items: [
      "We introduced robotics to students in the Mongol Language School in Arncliffe West and Canterbury.",
      "We helped start Sydney Boys High School's FTC Team, Sydney High Voltage.",
      "Some our team members travelled around rural Mongolia, exposing the children there to STEM and robotics.",
      "We held workshops at UNSW O-Week, recruiting some new university students as mentors in the process.",
      "We assisted OLSH College in starting a robotics elective using LEGO EV3s for Year 10 students.",
      "We held a robotics workshop at St George Girls High School, introducing Year 9s to programming LEGO EV3s.",
      "We started an initiative to have our students volunteer in multiple FLL and FTC competitions.",
    ],
  },
  {
    year: 2025,
    items: [
      "We, along with other Australian members of the FIRST community, started the Mihirungs Ri3D (Robot in 3 Days) team, and built an FRC robot in 3 days.",
      "Our FRC team were finalists at the 2025 Southern Cross Regional.",
      "Some of our students attended and presented at the 2025 International Astronautical Congress, reaching an international industry audience.",
      "We travelled to Melbourne to attend the Melbourne Robotics Tournament, connecting with the teams there.",
    ],
  },
  {
    year: 2026,
    items: [
      "We travelled to New York City to compete and connect with the FRC teams there.",
    ],
  },
];
---

<Layout title="About | EMU Robotics">
  <!-- GENERAL SECTION -->
  <section
    class="fade-in-up mx-auto mt-10 flex flex-col items-center gap-3 px-5 text-center md:max-w-[50%] md:px-0"
  >
    <h1 class="text-4xl font-bold">About EMU Robotics</h1>
    <h3 class="text-xl">
      We are a team of students who compete in FIRST competitions alongside a
      group of mentors who help us build robots.
    </h3>
    <ResponsiveImage src={teamImage} alt="team photo" />
  </section>

  <!-- SPONSORS SECTION -->
  <section
    class="fade-in-up mx-auto mt-6 flex flex-col items-center gap-3 p-5 text-center md:w-3/4 md:px-0 lg:w-2/3"
  >
    <h1 class="text-4xl font-bold">Our Sponsors</h1>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a
        href="https://www.unsw.edu.au/engineering/our-schools/electrical-engineering-telecommunications"
      >
        <ResponsiveImage
          src={unswLogo}
          class="aspect-video h-56 w-auto bg-white object-contain p-5"
          alt="UNSW School of Electrical Engineering and Telecommunications Logo"
        />
      </a>
      <a href="https://www.rockwellautomation.com/en-us.html">
        <ResponsiveImage
          src={rockwellLogo}
          class="aspect-video h-56 w-auto bg-white object-contain p-5"
          alt="Rockwell Automation Logo object-contain p-5"
        />
      </a>
      <a href="https://www.boeing.com/">
        <ResponsiveImage
          src={boeingLogo}
          class="aspect-video h-56 w-auto bg-white object-contain p-5"
          alt="Boeing Logo"
        />
      </a>
      <a href="https://ghaasfoundation.org/">
        <ResponsiveImage
          src={geneHaasLogo}
          class="aspect-video h-56 w-auto bg-white object-contain p-5"
          alt="Gene Haas Foundation Logo"
        />
      </a>
      <a href="https://www.intuitive-foundation.org/">
        <ResponsiveImage
          src={intuitiveLogo}
          class="aspect-video h-56 w-auto bg-white object-contain p-5"
          alt="Intuitive Foundation Logo"
        />
      </a>
    </div>
  </section>

  <!-- FOUNDING SECTION -->
  <section
    class="fade-in-up mx-auto flex flex-col gap-3 p-5 md:max-w-[50%] md:px-0"
  >
    <h1 class="text-4xl font-bold">Our Founding</h1>
    <p>
      Our first meeting was in December 2012, and at that time there were only 4
      mentors and 8 students. We wanted to and we still strive to be a diverse,
      inclusive place for passionate students to learn STEM and have fun through
      robotics.
    </p>
  </section>

  <!-- ACCOMPLISHMENTS SECTION -->
<section class="fade-in-up mx-auto flex flex-col gap-3 p-5 md:max-w-[50%] md:px-0">
  <h1 class="text-left text-4xl font-bold">Our Accomplishments</h1>
  <ResponsiveImage src={awardsImage} alt="Our awards cabinet" />

  <div class="relative mt-6">
    <!-- Spine — left-[18px] centers it through the 14px dots at left-[11px] -->
    <div class="absolute bottom-0 left-[18px] top-0 w-0.5 bg-gray-700"></div>

    <div class="flex flex-col gap-7">
      {accomplishments.map(({ year, items }) => {
        const isIntl = year === 2026;
        const isAward = [2016, 2018, 2021, 2022].includes(year);
        const isFounding = year === 2012;
        const isExpansion = [2019, 2023].includes(year);

        const dotBg = isIntl ? '#ef4444' : isAward ? '#f59e0b' : isFounding ? '#15803d' : 'transparent';
        const dotBorder = isIntl ? '#ef4444' : isAward ? '#f59e0b' : isFounding ? '#15803d' : '#6b7280';
        const cardBorderLeft = isIntl ? '3px solid #ef4444' : isAward ? '3px solid #f59e0b' : 'none';
        const cardBg = isIntl ? '#fef2f2' : 'var(--card-bg, #1a1a1a)';
        const textColor = isIntl ? '#7f1d1d' : '#9ca3af';
        const bulletBg = isIntl ? '#f87171' : isAward ? '#fbbf24' : '#6b7280';

        const badge = isIntl ? { label: 'International', bg: '#fee2e2', color: '#991b1b' }
          : isAward ? { label: 'Award', bg: '#fef3c7', color: '#92400e' }
          : isFounding ? { label: 'Founded', bg: '#dcfce7', color: '#166534' }
          : isExpansion ? { label: 'Expansion', bg: '#dbeafe', color: '#1e40af' }
          : null;

        return (
          <div class="relative pl-12">
            <!-- Dot: left-[11px] + width 14px = center at 18px, matching the spine -->
            <div
              class="absolute left-[11px] top-1.5 h-3.5 w-3.5 rounded-full border-2"
              style={{ backgroundColor: dotBg, borderColor: dotBorder }}
            />

            <div class="mb-2 flex items-center gap-2">
              <span class="text-xs font-semibold uppercase tracking-widest text-gray-400">{year}</span>
              {badge && (
                <span
                  class="rounded-full px-2 py-0.5 text-[10px] font-semibold"
                  style={{ backgroundColor: badge.bg, color: badge.color }}
                >
                  {badge.label}
                </span>
              )}
            </div>

            <div
              class="rounded-2xl border border-gray-800 px-5 py-4"
              style={{ backgroundColor: cardBg, borderLeft: cardBorderLeft }}
            >
              <ul class="flex flex-col gap-2">
                {items.map((item) => (
                  <li class="flex items-start gap-2 text-sm leading-relaxed" style={{ color: textColor }}>
                    <span
                      class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full"
                      style={{ backgroundColor: bulletBg }}
                    />
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <p class="mt-2 text-xl">
    That was a lot. If you want to be a part of our next accomplishments,{" "}
    <InlineLink href="/join">join us!</InlineLink>
  </p>
</section>
</Layout>
